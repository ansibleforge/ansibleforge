# vm-portal-gateway configuration — copy to .env for local dev, or supply via
# the systemd quadlet / podman secrets in production. Values here are PLACEHOLDERS.

# ---- HTTP / WebSocket server ----
# Port the gateway listens on inside the container (nginx proxies /ws/terminal here).
PORT=8081

# ---- AAP (OAuth token validation) ----
# Base URL of the AAP gateway. In the podman deployment the gateway reaches AAP the
# same way nginx does, via the rootless-podman host alias.
AAP_BASE_URL=https://host.containers.internal
# SNI / Host header to present to the AAP gateway (self-signed cert CN).
AAP_TLS_HOST=aap1.local
# Sandbox only: skip TLS verification of the self-signed AAP cert. Set to false and
# provide a CA bundle before exposing this beyond a sandbox.
AAP_TLS_INSECURE=true

# ---- AWS ----
AWS_REGION=us-east-2
# Avoid an IMDS lookup timeout on this non-AWS host.
AWS_EC2_METADATA_DISABLED=true
# Credentials: supply via podman secrets in prod (NOT committed). For local dev only:
# AWS_ACCESS_KEY_ID=AKIAEXAMPLE
# AWS_SECRET_ACCESS_KEY=examplesecret
# AWS_SESSION_TOKEN=

# ---- SSH / session policy ----
DEFAULT_SSH_USER=ec2-user
# Comma-separated allowlist of regions a client may target.
ALLOWED_REGIONS=us-east-1,us-east-2,us-west-2,eu-west-1,ap-southeast-2
# Require the instance to be tagged ManagedBy=ansible (matches the portal's gate).
REQUIRE_MANAGED_BY_ANSIBLE=true
IDLE_TIMEOUT_MS=600000
MAX_SESSION_MS=3600000
MAX_SESSIONS=50
MAX_SESSIONS_PER_USER=5
SSH_READY_TIMEOUT_MS=15000
